    "date-fns": "^4.1.0",
    "next": "^15.5.6",
    "openai": "^6.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "robots-parser": "^3.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
